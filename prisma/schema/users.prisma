model User {
  id           String     @id @default(uuid()) @db.Uuid
  fullName     String     @map("full_name")
  phone        String?    @unique
  email        String?    @unique
  roleId       String     @map("role_id") @db.Uuid
  departmentId String?    @map("department_id") @db.Uuid
  specialty    String?
  status       UserStatus @default(active)
  createdById  String?    @map("created_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime?  @updatedAt @map("updated_at")

  role              Role        @relation(fields: [roleId], references: [id])
  department        Department? @relation("DepartmentUsers", fields: [departmentId], references: [id])
  managedDepartment Department? @relation("DepartmentManager")
  createdBy         User?       @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers      User[]      @relation("UserCreatedBy")

  rolesCreated             Role[]                   @relation("RoleCreatedBy")
  otpCodes                 OtpCode[]
  sessions                 Session[]
  userPermissions          UserPermission[]         @relation("UserPermissionOwner")
  userPermissionsGranted   UserPermission[]         @relation("PermissionGrantedBy")
  createdProducts          Product[]
  createdProductVariants   ProductVariant[]
  createdStockSettings     DepartmentStockSetting[]
  prRequested              PurchaseRequest[]        @relation("PRRequestedBy")
  prHospitalApproved       PurchaseRequest[]        @relation("PRHospitalApprovedBy")
  prCommitteeApproved      PurchaseRequest[]        @relation("PRCommitteeApprovedBy")
  prCommitteeMarkedReady   PurchaseRequest[]        @relation("PRCommitteeMarkedReadyBy")
  createdPurchaseOrders    PurchaseOrder[]
  receivedPurchaseReceipts PurchaseReceipt[]
  createdBatches           Batch[]
  drRequested        DepartmentRefillRequest[]  @relation("DRRequestedBy")
  drHospitalApproved DepartmentRefillRequest[]  @relation("DRHospitalApprovedBy")
  deliveriesShipped  DepartmentRefillDelivery[] @relation("DeliveryDeliveredBy")
  deliveriesReceived DepartmentRefillDelivery[] @relation("DeliveryReceivedBy")
  performedInventoryTransactions InventoryTransaction[]
  reportedInventoryAdjustments   InventoryAdjustment[]
  initiatedStockCountSessions StockCountSession[]
  registeredPatients Patient[]
  queueEntriesAdded   DepartmentQueue[] @relation("QueueAddedBy")
  queueEntriesLocked  DepartmentQueue[] @relation("QueueLockedBy")
  queueEntriesRemoved DepartmentQueue[] @relation("QueueRemovedBy")
  doctorVisits     MedicalVisit[] @relation("VisitDoctor")
  visitsCancelled  MedicalVisit[] @relation("VisitCancelledBy")
  prescriptionsWritten     Prescription[] @relation("PrescriptionDoctor")
  prescriptionsCancelled   Prescription[] @relation("PrescriptionCancelledBy")
  // users.prisma -- inside model User, add:
  periodicSchedulesCreated  PeriodicRefillSchedule[] @relation("PeriodicScheduleCreatedBy")
  periodicSchedulesApproved PeriodicRefillSchedule[] @relation("PeriodicScheduleApprovedBy")
  periodicSchedulesCancelled PeriodicRefillSchedule[] @relation("PeriodicScheduleCancelledBy")
  prescriptionDispenses PrescriptionDispense[]
  
  @@map("users")
}
