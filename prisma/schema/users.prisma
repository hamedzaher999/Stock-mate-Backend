model User {
  id           String     @id @default(uuid()) @db.Uuid
  fullName     String     @map("full_name")
  phone        String?    @unique
  email        String?    @unique
  roleId       String     @map("role_id") @db.Uuid
  departmentId String?    @map("department_id") @db.Uuid
  specialty    String?
  status       UserStatus @default(active)
  createdById  String?    @map("created_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime?  @updatedAt @map("updated_at")

  role              Role             @relation(fields: [roleId], references: [id])
  department        Department?      @relation("DepartmentUsers", fields: [departmentId], references: [id])
  managedDepartment Department?      @relation("DepartmentManager")
  createdBy         User?            @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers      User[]           @relation("UserCreatedBy")

  rolesCreated           Role[]           @relation("RoleCreatedBy")
  otpCodes               OtpCode[]
  sessions               Session[]
  userPermissions        UserPermission[] @relation("UserPermissionOwner")
  userPermissionsGranted UserPermission[] @relation("PermissionGrantedBy")
  createdProducts        Product[]
  createdProductVariants ProductVariant[]
  @@map("users")
}