generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive

  @@map("user_status")
}

enum DepartmentType {
  central_warehouse
  pharmacy
  standard

  @@map("department_type")
}

enum OtpChannel {
  phone
  email

  @@map("otp_channel")
}

enum SessionPlatform {
  web
  mobile

  @@map("session_platform")
}

enum PermissionEffect {
  grant
  revoke

  @@map("permission_effect")
}

enum PurchaseRequestStatus {
  draft
  submitted
  pending_hospital_approval
  rejected
  pending_purchasing_committee
  approved
  ready_for_receiving
  partially_received
  received
  cancelled

  @@map("purchase_request_status")
}

enum PurchaseOrderStatus {
  draft
  sent
  partially_received
  received
  cancelled

  @@map("purchase_order_status")
}
