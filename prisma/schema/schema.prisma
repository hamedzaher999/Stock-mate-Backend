generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive

  @@map("user_status")
}

enum DepartmentType {
  central_warehouse
  pharmacy
  standard

  @@map("department_type")
}

enum OtpChannel {
  phone
  email

  @@map("otp_channel")
}

enum SessionPlatform {
  web
  mobile

  @@map("session_platform")
}

enum PermissionEffect {
  grant
  revoke

  @@map("permission_effect")
}

enum PurchaseRequestStatus {
  draft
  submitted
  pending_hospital_approval
  rejected
  pending_purchasing_committee
  approved
  ready_for_receiving
  partially_received
  received
  cancelled

  @@map("purchase_request_status")
}

enum PurchaseOrderStatus {
  draft
  sent
  partially_received
  received
  cancelled

  @@map("purchase_order_status")
}
enum RefillRequestStatus {
  draft
  pending_hospital_approval
  approved
  preparing
  ready_for_delivery
  delivered
  partially_delivered
  cancelled

  @@map("refill_request_status")
}

enum TransactionType {
  purchase_receipt
  department_transfer_out
  department_transfer_in
  prescription_dispense
  department_consumption
  adjustment_damaged
  adjustment_expired
  adjustment_shrinkage
  adjustment_found

  @@map("transaction_type")
}

enum AdjustmentType {
  damaged
  expired
  shrinkage
  found

  @@map("adjustment_type")
}

enum ReferenceType {
  purchase_receipt
  refill_request
  department_refill_delivery_item
  prescription_dispense
  adjustment
  stock_count

  @@map("reference_type")
}

enum StockCountStatus {
  draft
  completed

  @@map("stock_count_status")
}

enum QueueStatus {
  waiting
  in_consultation
  completed
  removed

  @@map("queue_status")
}

enum VisitStatus {
  completed
  cancelled

  @@map("visit_status")
}

enum PrescriptionStatus {
  active
  completed
  cancelled

  @@map("prescription_status")
}

enum CycleStatus {
  ready
  partially_delivered
  delivered
  missed
  cancelled

  @@map("cycle_status")
}

enum FrequencyUnit {
  day
  week
  month

  @@map("frequency_unit")
}


enum RefillRequestPriority {
  normal
  urgent

  @@map("refill_request_priority")
}

enum RefillRequestType {
  normal
  daily
  weekly
  monthly

  @@map("refill_request_type")
}

enum PeriodicScheduleStatus {
  active
  cancelled

  @@map("periodic_schedule_status")
}

enum ScheduleApprovalPolicy {
  auto_approved
  approval_required_each_cycle

  @@map("schedule_approval_policy")
}



enum NotificationCategory {
    inventory
    queue
    pharmacy
    purchasing
    ai_insight

    @@map("notification_category")
}