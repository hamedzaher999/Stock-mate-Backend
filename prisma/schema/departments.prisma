model Department {
  id        String         @id @default(uuid()) @db.Uuid
  name      String         @unique
  type      DepartmentType @default(standard)
  managerId String?        @unique @map("manager_id") @db.Uuid
  isActive  Boolean        @default(true) @map("is_active")
  tracksInventory Boolean  @default(true) @map("tracks_inventory")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime?      @updatedAt @map("updated_at")

  manager       User?                    @relation("DepartmentManager", fields: [managerId], references: [id])
  users         User[]                   @relation("DepartmentUsers")
  batchStocks   BatchStock[]
  stockSettings DepartmentStockSetting[]
  refillRequests       DepartmentRefillRequest[]
  inventoryTransactions InventoryTransaction[]
  inventoryAdjustments  InventoryAdjustment[]
  stockCountSessions StockCountSession[]
  queueEntries DepartmentQueue[]
  medicalVisits MedicalVisit[]
  periodicRefillSchedules PeriodicRefillSchedule[]

  @@map("departments")
}